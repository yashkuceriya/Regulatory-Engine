# Cover Regulatory Engine — Environment Variables
# Copy to .env and fill in your values

# LLM (Claude) — required for synthesis layer
ANTHROPIC_API_KEY=sk-ant-...

# Mapbox — required for interactive map
MAPBOX_TOKEN=pk.eyJ...

# Database (production — Railway/Supabase)
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/regulatory

# Fallback geocoder (optional)
# GOOGLE_MAPS_API_KEY=...
